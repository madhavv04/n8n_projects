    {
      "parameters": {
        "jsCode": "// Flatten all repos from all users/orgs and deduplicate\nconst seen = new Set();\nconst result = [];\n\nfor (const item of $input.all()) {\n  const repos = Array.isArray(item.json) ? item.json : [item.json];\n  for (const repo of repos) {\n    if (!repo || !repo.full_name) continue;\n    if (seen.has(repo.full_name)) continue;\n    seen.add(repo.full_name);\n    result.push({ json: { full_name: repo.full_name } });\n  }\n}\n\nif (!result.length) throw new Error('No repositories found.');\nreturn result;"
      },
