        "jsCode": "const aiText = $json.choices[0].message.content;\nconst { emails, today } = $('Prepare Data').first().json;\n\nconst html = `\n<html><body style=\"font-family:Arial,sans-serif;max-width:700px;margin:auto;padding:24px;color:#1a1a1a\">\n  <div style=\"background:#0d1117;padding:20px 24px;border-radius:8px 8px 0 0\">\n    <h1 style=\"color:#58a6ff;margin:0;font-size:20px\">🚀 GitHub Release Digest</h1>\n    <p style=\"color:#8b949e;margin:6px 0 0\">${today}</p>\n  </div>\n  <div style=\"border:1px solid #e1e4e8;border-top:none;padding:24px;border-radius:0 0 8px 8px\">\n    <h2 style=\"font-size:22px;font-weight:700;margin:0 0 6px\">GitHub Release Summary</h2>\n    <p style=\"font-size:15px;color:#555;margin:0 0 24px\">Here are the releases from the past 24 hours:</p>\n    ${aiText}\n  </div>\n</body></html>\n`;\n\nreturn [{ json: { html, emailsTo: emails, subject: `GitHub Release Digest — ${today}` } }];"
      },
