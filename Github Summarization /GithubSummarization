    {
      "parameters": {
        "jsCode": "const releases = $json.releases || [];\nconst emails = $('Parse Emails').first().json.emails || $('.env').first().json.EMAIL_TO;\nconst today = new Date().toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });\n\nconst summary = releases.map(r =>\n  `Repo: ${r.repo}\\nVersion: ${r.tag} — ${r.name}\\nPublished: ${r.published_at}\\nURL: ${r.url}\\nNotes:\\n${r.body}`\n).join('\\n\\n---\\n\\n');\n\nreturn [{ json: { hasReleases: true, emails, today, summary, count: releases.length } }];"
      },
      "id": "0f2d0b7e-8dc2-4342-93d3-9145d7987028",
      "name": "Prepare Data",
      "type": "n8n-nodes-base.code",
