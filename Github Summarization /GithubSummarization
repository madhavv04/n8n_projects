    {
      "parameters": {
        "jsCode": "const error = $('Error Trigger').first().json;\nconst adminEmail = $('Parse Emails For EL').first().json.emails;\nconst now = new Date().toLocaleString('en-US', { weekday:'long', year:'numeric', month:'long', day:'numeric', hour:'2-digit', minute:'2-digit' });\n\nconst failedNode = error.execution?.error?.node?.name || 'Unknown Node';\nconst errorMessage = error.execution?.error?.message || 'Unknown error';\nconst errorStack = error.execution?.error?.stack || '';\nconst workflowName = error.workflow?.name || 'GitHub Summarization';\nconst executionId = error.execution?.id || 'N/A';\nconst workflowId = error.workflow?.id || '';\n\n// ✅ Extract base URL from execution.url (contains correct subdomain)\nlet executionUrl = `Execution ID: ${executionId}`;\nif (error.execution?.url) {\n  executionUrl = error.execution.url;\n} else if (error.execution?.resumeUrl) {\n  executionUrl = error.execution.resumeUrl.replace('/resume', '');\n}\n\nconst html = `\n<html><body style=\"font-family:Arial,sans-serif;max-width:700px;margin:auto;padding:24px;color:#1a1a1a\">\n  <div style=\"background:#b91c1c;padding:20px 24px;border-radius:8px 8px 0 0\">\n    <h1 style=\"color:#fff;margin:0;font-size:20px\">⚠️ Workflow Error Alert</h1>\n    <p style=\"color:#fecaca;margin:6px 0 0\">${now}</p>\n  </div>\n  <div style=\"border:1px solid #fca5a5;border-top:none;padding:24px;border-radius:0 0 8px 8px;background:#fff5f5\">\n    <table style=\"width:100%;border-collapse:collapse;font-size:14px\">\n      <tr style=\"border-bottom:1px solid #fecaca\">\n        <td style=\"padding:10px 8px;font-weight:700;color:#991b1b;width:160px\">Workflow</td>\n        <td style=\"padding:10px 8px\">${workflowName}</td>\n      </tr>\n      <tr style=\"border-bottom:1px solid #fecaca\">\n        <td style=\"padding:10px 8px;font-weight:700;color:#991b1b\">Failed Node</td>\n        <td style=\"padding:10px 8px;font-family:monospace;background:#fee2e2;border-radius:4px\">${failedNode}</td>\n     