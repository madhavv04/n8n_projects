    {
      "parameters": {
        "jsCode": "// Build GitHub API URLs for each user and org\nconst calls = [];\n\nfor (const item of $input.all()) {\n  const active = (item.json.active || 'yes').toLowerCase();\n  if (active === 'no' || active === 'false') continue;\n\n  if (item.json.username && item.json.username.trim()) {\n    const u = item.json.username.trim();\n    calls.push({ type: 'user', name: u, url: `https://api.github.com/users/${u}/repos?per_page=100&type=owner` });\n  }\n  if (item.json.org && item.json.org.trim()) {\n    const o = item.json.org.trim();\n    calls.push({ type: 'org', name: o, url: `https://api.github.com/orgs/${o}/repos?per_page=100` });\n  }\n}\n\nif (!calls.length) throw new Error('No active users or orgs found in Google Sheet.');\nreturn calls.map(c => ({ json: c }));"
      },
