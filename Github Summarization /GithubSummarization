    {
      "parameters": {
        "jsCode": "// Run once for ALL items — handles n repos with n releases each\nconst cutoff = new Date(Date.now() - 24 * 60 * 60 * 1000);\nconst results = [];\n\nfor (const item of $input.all()) {\n  const input = item.json;\n  const releases = Array.isArray(input) ? input : [input];\n\n  for (const r of releases) {\n    if (!r?.published_at) continue;\n    if (new Date(r.published_at) < cutoff) continue;\n\n    const repo = r.html_url\n      .split('/releases/')[0]\n      .replace('https://github.com/', '');\n\n    results.push({\n      json: {\n        repo,\n        tag: r.tag_name,\n        name: r.name || r.tag_name,\n        url: r.html_url,\n        published_at: r.published_at,\n        body: (r.body || 'No release notes provided.').substring(0, 1500)\n      }\n    });\n  }\n}\n\n// If no releases found — return flag immediately, workflow branches to no-release email\nif (results.length === 0) {\n  return [{ json: { noReleases: true } }];\n}\n\nreturn results;"
      },
