        "jsCode": "// SEC-PMS-001 FIXED | Enhanced CEO-level Email\n\nfunction escapeHtml(unsafe) {\n  return String(unsafe || '')\n    .replace(/&/g, '&amp;')\n    .replace(/</g, '&lt;')\n    .replace(/>/g, '&gt;')\n    .replace(/\"/g, '&quot;')\n    .replace(/'/g, '&#039;');\n}\n\nfunction statusBadge(status) {\n  const s = (status || '').toLowerCase();\n  const colors = {\n    'new':         { bg: '#e8f0fe', color: '#1a73e8' },\n    'in progress': { bg: '#fce8b2', color: '#b06000' },\n    'resolved':    { bg: '#e6f4ea', color: '#137333' },\n    'closed':      { bg: '#e6f4ea', color: '#137333' },\n    'feedback':    { bg: '#fce8b2', color: '#b06000' },\n    'rejected':    { bg: '#fce8b2', color: '#c5221f' }\n  };\n  const c = colors[s] || { bg: '#f1f3f4', color: '#5f6368' };\n  return `<span style=\"background:${c.bg};color:${c.color};font-size:10px;font-weight:600;padding:2px 7px;border-radius:10px;white-space:nowrap;\">${escapeHtml(status)}</span>`;\n}\n\nconst activities = $input.first().json.activities || [];\nconst displayDate = $('Set Today Date').first().json.displayDate;\n\nif (activities.length === 0 || activities[0]?.empty) {\n  return [{ json: {\n    html: `<html><body style=\"font-family:Arial;padding:20px;background:#f6f8fc;\"><p>No activity recorded for ${escapeHtml(displayDate)}.</p></body></html>`,\n    subject: `Daily PMS Report — ${displayDate}`\n  }}];\n}\n\nconst byProject = {};\nfor (const a of activities) {\n  const key = a.projectName || 'Unknown';\n  if (!byProject[key]) byProject[key] = [];\n  byProject[key].push(a);\n}\n\nconst totalUpdates = activities.length;\nconst totalProjects = Object.keys(byProject).length;\nconst uniqueDevs = [...new Set(activities.map(a => a.developer).filter(Boolean))];\nconst totalDevs = uniqueDevs.length;\nconst totalHours = activities.reduce((s, a) => s + (Number(a.spentHours) || 0), 0).toFixed(1);\n// const totalHours = activities.reduce((s, a) => s + (Number(a.spentHours) || 0), 0);\n\n// Top developers by update count\nconst devCounts = {};\nactivities.forEach(a => { if(a.developer) devCounts[a.developer] = (devCounts[a.developer]||0)+1; });\nconst topDevs = Object.entries(devCounts).sort((a,b)=>b[1]-a[1]).slice(0,3);\n\nlet projectTablesHtml = '';\nfor (const [projName, tasks] of Object.entries(byProject)) {\n  const projHours = tasks.reduce((s,t) => s+(Number(t.spentHours)||0),0).toFixed(1);\n  // const projHours = tasks.reduce((s,t) => s+(Number(t.spentHours)||0),0);\n  const rows = tasks.map((t, i) => `\n    <tr style=\"${i % 2 === 1 ? 'background:#fafbff;' : 'background:#fff;'}\">\n      <td style=\"padding:10px 12px;border-bottom:1px solid #f1f3f4;color:#1a73e8;font-size:11px;font-weight:600;white-space:nowrap;vertical-align:top;width:70px;\">${escapeHtml(t.taskId || '')}</td>\n      <td style=\"padding:10px 12px;border-bottom:1px solid #f1f3f4;color:#202124;font-size:12px;vertical-align:top;\">${escapeHtml(t.taskTitle || '')}</td>\n      <td style=\"padding:10px 12px;border-bottom:1px solid #f1f3f4;font-size:11px;vertical-align:top;width:100px;\">${statusBadge(t.status)}</td>\n      <td style=\"padding:10px 12px;border-bottom:1px solid #f1f3f4;color:#1a73e8;font-size:12px;white-space:nowrap;vertical-align:top;width:120px;\">${escapeHtml(t.developer || '')}</td>\n      <td style=\"padding:10px 12px;border-bottom:1px solid #f1f3f4;color:#3c4043;font-size:12px;line-height:1.7;vertical-align:top;\">${escapeHtml(t.summary || t.activity || '').replace(/\\n/g, '<br>')}</td>\n    </tr>`).join('');\n\n  projectTablesHtml += `\n  <div style=\"margin-bottom:28px;\">\n    <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin-bottom:8px;\">\n      <tr>\n        <td style=\"font-size:15px;font-weight:700;color:#202124;vertical-align:middle;\">📁 ${escapeHtml(projName)}</td>\n        <td align=\"right\" style=\"vertical-align:middle;\">\n          <span style=\"background:#e8f0fe;color:#1a73e8;font-size:11px;font-weight:700;padding:3px 10px;border-radius:10px;\">${tasks.length} update${tasks.length>1?'s':''}</span>\n          ${projHours > 0 ? `<span style=\"background:#e6f4ea;color:#137333;font-size:11px;font-weight:700;padding:3px 10px;border-radius:10px;margin-left:6px;\">⏱ ${projHours}h</span>` : ''}\n        </td>\n      </tr>\n    </table>\n    <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border-collapse:collapse;border:1px solid #e8eaed;border-radius:6px;overflow:hidden;\">\n      <tr style=\"background:#f8f9fa;\">\n        <th style=\"padding:8px 12px;text-align:left;color:#5f6368;font-weight:700;font-size:10px;text-transform:uppercase;letter-spacing:0.5px;border-bottom:2px solid #e8eaed;width:70px;\">Task ID</th>\n        <th style=\"padding:8px 12px;text-align:left;color:#5f6368;font-weight:700;font-size:10px;text-transform:uppercase;letter-spacing:0.5px;border-bottom:2px solid #e8eaed;\">Task</th>\n        <th style=\"padding:8px 12px;text-align:left;color:#5f6368;font-weight:700;font-size:10px;text-transform:uppercase;letter-spacing:0.5px;border-bottom:2px solid #e8eaed;width:100px;\">Status</th>\n        <th style=\"padding:8px 12px;text-align:left;color:#5f6368;font-weight:700;font-size:10px;text-transform:uppercase;letter-spacing:0.5px;border-bottom:2px solid #e8eaed;width:120px;\">Developer</th>\n        <th style=\"padding:8px 12px;text-align:left;color:#5f6368;font-weight:700;font-size:10px;text-transform:uppercase;letter-spacing:0.5px;border-bottom:2px solid #e8eaed;\">Activity Summary</th>\n      </tr>\n      ${rows}\n    </table>\n  </div>`;\n}\n\n// Top devs bar\nconst topDevsHtml = topDevs.map(([name, count]) =>\n  `<span style=\"display:inline-block;background:#f1f3f4;border-radius:20px;padding:4px 12px;font-size:11px;color:#202124;margin:3px;\">👤 ${escapeHtml(name)} <strong>${count}</strong></span>`\n).join('');\n\nconst html = `<!DOCTYPE html>\n<html lang=\"en\">\n<head><meta charset=\"UTF-8\"><title>Daily PMS Report</title></head>\n<body style=\"margin:0;padding:0;background:#f0f4f8;font-family:Arial,sans-serif;\">\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f0f4f8;padding:24px 0;\">\n<tr><td align=\"center\">\n<table width=\"720\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:720px;width:100%;background:#fff;border-radius:8px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.08);\">\n\n  <!-- HEADER -->\n  <tr><td style=\"background:linear-gradient(135deg,#1a73e8 0%,#0d47a1 100%);padding:24px 28px;\">\n    <table width=\"100%\"><tr>\n      <td>\n        <div style=\"font-size:11px;color:#a8c7fa;letter-spacing:1px;text-transform:uppercase;margin-bottom:4px;\">Xcellence-IT · PMS Monitor</div>\n        <div style=\"font-size:22px;font-weight:800;color:#fff;letter-spacing:-0.3px;\">Daily Project Updates</div>\n        <div style=\"font-size:12px;color:#c5d9f8;margin-top:4px;\">${escapeHtml(displayDate)}</div>\n      </td>\n      <td align=\"right\" style=\"vertical-align:top;\">\n        <div style=\"background:rgba(255,255,255,0.15);border-radius:8px;padding:10px 16px;text-align:center;\">\n          <div style=\"font-size:28px;font-weight:800;color:#fff;\">${totalUpdates}</div>\n          <div style=\"font-size:10px;color:#c5d9f8;text-transform:uppercase;letter-spacing:0.5px;\">Total Updates</div>\n        </div>\n      </td>\n    </tr></table>\n  </td></tr>\n\n  <!-- STATS BAR -->\n  <tr><td style=\"padding:0;\">\n    <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#1557b0;\">\n      <tr>\n        <td align=\"center\" style=\"padding:12px;border-right:1px solid rgba(255,255,255,0.1);\">\n          <div style=\"font-size:18px;font-weight:800;color:#fff;\">${totalProjects}</div>\n          <div style=\"font-size:10px;color:#a8c7fa;text-transform:uppercase;\">Projects</div>\n        </td>\n        <td align=\"center\" style=\"padding:12px;border-right:1px solid rgba(255,255,255,0.1);\">\n          <div style=\"font-size:18px;font-weight:800;color:#fff;\">${totalDevs}</div>\n          <div style=\"font-size:10px;color:#a8c7fa;text-transform:uppercase;\">Developers</div>\n        </td>\n        <td align=\"center\" style=\"padding:12px;\">\n          <div style=\"font-size:18px;font-weight:800;color:#fff;\">${totalHours}h</div>\n          <div style=\"font-size:10px;color:#a8c7fa;text-transform:uppercase;\">Hours Logged</div>\n        </td>\n      </tr>\n    </table>\n  </td></tr>\n\n  <!-- TOP CONTRIBUTORS -->\n  ${topDevs.length > 0 ? `\n  <tr><td style=\"padding:12px 28px;background:#f8f9ff;border-bottom:1px solid #e8eaed;\">\n    <span style=\"font-size:11px;color:#5f6368;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;margin-right:8px;\">Top Contributors:</span>\n    ${topDevsHtml}\n  </td></tr>` : ''}\n\n  <!-- PROJECT TABLES -->\n  <tr><td style=\"padding:20px 28px;\">\n    ${projectTablesHtml}\n  </td></tr>\n\n  <!-- FOOTER -->\n  <tr><td style=\"padding:14px 28px;background:#f8f9fa;border-top:1px solid #e8eaed;\">\n    <table width=\"100%\"><tr>\n      <td style=\"font-size:11px;color:#9aa0a6;\">Auto-generated by PMS Monitoring AI Agent · pms.xcellence-it.com</td>\n      <td align=\"right\" style=\"font-size:11px;color:#9aa0a6;\">Xcellence-IT Internal Report</td>\n    </tr></table>\n  </td></tr>\n\n</table>\n</td></tr>\n</table>\n</body></html>`;\n\nreturn [{ json: { html, subject: `📊 Daily PMS Report — ${displayDate} (${totalUpdates} Updates, ${totalProjects} Projects)` } }];"
      },
