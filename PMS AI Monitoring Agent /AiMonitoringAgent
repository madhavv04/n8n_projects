    {
      "parameters": {
        "jsCode": "// FIXED: Run Once for All Items — extracts project name from Split Issues node as fallback\nconst yesterday = $('Split Issues').first().json.yesterday;\n\n// Build a lookup map from Split Issues for projectName fallback\nconst splitMap = {};\nfor (const si of $('Split Issues').all()) {\n  splitMap[String(si.json.issueId)] = si.json.projectName;\n}\n\nconst results = [];\n\nfor (const item of $input.all()) {\n  const issue = item.json.issue;\n  if (!issue) continue;\n\n  // Use detail API project name first, then fall back to Split Issues map\n  const projectName = issue.project?.name\n    || splitMap[String(issue.id)]\n    || issue.category?.name\n    || `Project #${issue.project?.id}`\n    || 'Unknown';\n\n  const taskId = `#${issue.id}`;\n  const taskTitle = issue.subject || '';\n  const status = issue.status?.name || '';\n  const spentHours = issue.spent_hours || 0;\n  const journals = issue.journals || [];\n\n  const yesterdayJournals = journals.filter(j => {\n    const jDate = j.created_on ? j.created_on.substring(0, 10) : '';\n    return jDate === yesterday;\n  });\n\n  if (yesterdayJournals.length === 0) continue;\n\n  yesterdayJournals.forEach(journal => {\n    const author = journal.user?.name || 'Unknown';\n    const notes = journal.notes || '';\n    const details = journal.details || [];\n\n    const changes = details.map(d => {\n      if (d.property === 'attr') {\n        return `${d.name}: ${d.old_value || '—'} → ${d.new_value || '—'}`;\n      }\n      return null;\n    }).filter(Boolean);\n\n    const activityParts = [];\n    if (notes) activityParts.push(`💬 ${notes}`);\n    if (changes.length) activityParts.push(`🔄 ${changes.join(', ')}`);\n    if (activityParts.length === 0) return;\n\n    results.push({\n      json: {\n        projectName,\n        taskId,\n        taskTitle,\n        developer: author,\n        status,\n        spentHours,\n        activity: activityParts.join(' | ')\n      }\n    });\n  });\n}\n\nif (results.length === 0) {\n  return [{ json: { empty: true } }];\n}\n\nreturn results;"
      },
