        "jsCode": "const now = new Date();\nconst yesterday = new Date(now);\nyesterday.setDate(now.getDate());\nconst yyyy = yesterday.getFullYear();\nconst mm = String(yesterday.getMonth()+1).padStart(2,'0');\nconst dd = String(yesterday.getDate()).padStart(2,'0');\nconst dateStr = `${yyyy}-${mm}-${dd}`;\nconst display = yesterday.toLocaleDateString('en-GB', {weekday:'long', day:'2-digit', month:'long', year:'numeric'});\nreturn [{ json: { yesterday: dateStr, displayDate: display } }];"
