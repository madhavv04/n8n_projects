      "parameters": {
        "jsCode": "const results = [];\nconst allItems = $input.all();\n\n// Build a lookup from Preserve Original Fields by index\nconst origItems = $('Preserve Original Fields').all();\n\nfor (let i = 0; i < allItems.length; i++) {\n  const item = allItems[i];\n  const raw = item.json.output || item.json.text || '';\n\n  // Get the original fields from the same-index Preserve node item\n  const origItem = origItems[i]?.json || {};\n  const orig = {\n    projectName: origItem._orig?.projectName || origItem.projectName || 'Unknown',\n    taskId:      origItem._orig?.taskId      || origItem.taskId      || '',\n    taskTitle:   origItem._orig?.taskTitle   || origItem.taskTitle   || '',\n    developer:   origItem._orig?.developer   || origItem.developer   || 'Unknown',\n    status:      origItem._orig?.status      || origItem.status      || '',\n    spentHours:  origItem._orig?.spentHours  ?? origItem.spentHours  ?? 0,\n  };\n\n  let parsed;\n  try {\n    const cleaned = raw.replace(/```json|```/g, '').trim();\n    parsed = raw.trim() ? JSON.parse(cleaned) : {};\n  } catch(e) {\n    parsed = { summary: raw };\n  }\n\n  // const summaryRaw = parsed.summary || raw || '';\n  const summaryRaw = String(parsed.summary || raw || '');\n  const lines = summaryRaw.split('\\n').map(l => l.trim()).filter(l => l.length > 0);\n  const bullets = lines.map(l => {\n    if (l.startsWith('•')) return l;\n    if (l.startsWith('-') || l.startsWith('*')) return '• ' + l.substring(1).trim();\n    return '• ' + l;\n  });\n\n  results.push({\n    json: {\n      projectName: orig.projectName,\n      taskId:      orig.taskId,\n      taskTitle:   orig.taskTitle,\n      developer:   orig.developer,\n      status:      orig.status,\n      spentHours:  orig.spentHours,\n      summary:     bullets.length > 0 ? bullets.join('\\n') : (origItem._orig?.activity || 'No summary available')\n    }\n  });\n}\n\nreturn results;"
      },
