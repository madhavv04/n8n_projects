      "parameters": {
        "jsCode": "let raw =\n  $json.text ||\n  $json.output ||\n  $json.response ||\n  JSON.stringify($json);\n\n// 🧹 Step 1: Extract JSON\nlet jsonMatch = raw.match(/\\{[\\s\\S]*\\}/);\n\nif (!jsonMatch) {\n  throw new Error(\"No JSON found in LLM response\");\n}\n\nlet cleanJson = jsonMatch[0];\n\n// 🧹 Step 2: Fix common issues\ncleanJson = cleanJson\n  .replace(/,\\s*}/g, \"}\")\n  .replace(/,\\s*]/g, \"]\");\n\n// 🧠 Step 3: Parse safely\nlet parsed;\n\ntry {\n  parsed = JSON.parse(cleanJson);\n} catch (e) {\n  throw new Error(\"Still invalid JSON after cleanup\");\n}\n\n// ✅ Return\nreturn [\n  {\n    status: \"success\",\n    data: parsed\n  }\n];"
