      "parameters": {
        "jsCode": "let text = $json.clean_text || \"\";\n\nlet education = [];\n\n// detect degree keywords\nlet degrees = [\n  \"bachelor\", \"b.tech\", \"b.e\", \"bsc\",\n  \"master\", \"m.tech\", \"msc\",\n  \"diploma\", \"phd\", \"12th\", \"10th\"\n];\n\nlet lines = text.split(/[\\n\\.]/);\n\nlines.forEach(line => {\n  let l = line.toLowerCase();\n\n  degrees.forEach(deg => {\n    if (l.includes(deg)) {\n      let years = line.match(/\\b(19|20)\\d{2}\\b/g);\n\n      education.push({\n        degree: line.trim(),\n        institution: null,\n        field_of_study: null,\n        grade: null,\n        percentage: null,\n        start_year: years ? years[0] : null,\n        end_year: years ? years[1] || null : null,\n        currently_studying: false\n      });\n    }\n  });\n});\n\nreturn [{\n  clean_text: text,\n  detected_education: education\n}];"
