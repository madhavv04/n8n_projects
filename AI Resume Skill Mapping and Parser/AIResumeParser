        "jsCode": "let data = $json.data;\n\n// ensure structure\ndata.flags = data.flags || [];\ndata.confidence = data.confidence || {};\n\n// --------------------\n// ✅ EDUCATION CHECK\n// --------------------\nif (!data.education || data.education.length === 0) {\n  data.flags.push(\"Education details incomplete\");\n}\n\n// fix years\ndata.education = (data.education || []).map(e => {\n  if (e.start_year && e.end_year && e.start_year > e.end_year) {\n    let temp = e.start_year;\n    e.start_year = e.end_year;\n    e.end_year = temp;\n  }\n  return e;\n});\n\n// --------------------\n// ✅ CONFIDENCE BOOST\n// --------------------\n\n// skill confidence refine\nif (data.skills?.length > 10) {\n  data.confidence.skills = 90;\n}\n\n// experience refine\nif (data.experience_years >= 3) {\n  data.confidence.experience = 90;\n}\n\n// --------------------\n// ✅ RETURN\n// --------------------\nreturn [{ data }];"
